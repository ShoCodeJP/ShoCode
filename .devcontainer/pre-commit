#!/bin/bash

# Get list of staged markdown files
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM -- '*.md')

if [ -z "$STAGED_MD" ]; then
  echo "No staged markdown files — skipping checks."
  exit 0
fi

EXIT_CODE=0

# Run Markdown linter on staged files only
echo "** Markdown Linting **"
if command -v markdownlint &> /dev/null; then
  echo "$STAGED_MD" | xargs markdownlint --config .markdownlint.yaml
  if [ $? -ne 0 ]; then
    echo "Markdown linting failed. Please fix the issues before committing."
    EXIT_CODE=1
  fi
else
  echo "Warning: markdownlint not found. Skipping."
fi

# Run link checker on staged files only
echo "** Markdown Link Check **"
if command -v markdown-link-check &> /dev/null; then
  echo "$STAGED_MD" | xargs -I {} markdown-link-check -c .markdownlinkcheck.json -q {}
  if [ $? -ne 0 ]; then
    echo "Link checking failed. Please fix the issues before committing."
    EXIT_CODE=1
  fi
else
  echo "Warning: markdown-link-check not found. Skipping."
fi

exit $EXIT_CODE
